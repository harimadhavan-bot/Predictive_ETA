# SAP AI Core Credentials
# Obtain from your SAP BTP subaccount → Instances and Subscriptions → AI Core service key

# OAuth2 Client Credentials (from AI Core service key)
AI_CORE_CLIENT_ID=your_client_id_here
AI_CORE_CLIENT_SECRET=your_client_secret_here

# Auth URL (from AI Core service key: url field)
AI_CORE_AUTH_URL=https://your-subaccount.authentication.sap.hana.ondemand.com

# AI Core API Base URL (from AI Core service key: serviceurls.AI_API_URL field)
AI_CORE_BASE_URL=https://api.ai.prod.eu-central-1.aws.ml.hana.ondemand.com

# Resource Group (default or your custom group)
AI_CORE_RESOURCE_GROUP=default

# RPT1.5 Model Deployment ID (from AI Core → ML Operations → Deployments)
AI_CORE_DEPLOYMENT_ID=your_rpt15_deployment_id_here

# Optional: Mock mode (set to "true" to skip real AI Core calls for testing)
MOCK_AI_CORE=false

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
